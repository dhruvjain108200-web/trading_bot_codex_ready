# COLAB RUNTIME WATCHDOG
# ============================================================

import threading
import time

def runtime_watchdog():

    print("Watchdog started")

    while True:
        try:
            if supervisor._thread is None or not supervisor._thread.is_alive():
                print("[WATCHDOG] Supervisor thread stopped unexpectedly")

            try:
                ws_ok = ws_pipeline.health.ws_connected
            except Exception:
                ws_ok = False

            if not ws_ok:
                print("[WATCHDOG] WebSocket appears disconnected")

            print(
                "[WATCHDOG]",
                "state=", supervisor.system_state,
                "last_cycle=", supervisor.last_cycle_status,
                "ws_connected=", ws_ok
            )

        except Exception as e:
            print("[WATCHDOG ERROR]", e)

        time.sleep(60)

watchdog_thread = threading.Thread(
    target=runtime_watchdog,
    daemon=True
)

watchdog_thread.start()
