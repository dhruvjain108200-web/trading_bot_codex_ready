class RealBotMaintenanceProvider:

    def __init__(self, root: str):
        self.root = root.rstrip("/")
        self.path_map = {
            "watchlist.json": f"{self.root}/lists/watchlist.json",
            "potential_stocks.json": f"{self.root}/lists/potential_stocks.json",
            "daily_movers_cache.json": f"{self.root}/lists/daily_movers_cache.json",
            "daily_losers_cache.json": f"{self.root}/lists/daily_losers_cache.json",
            "index_taxonomy.json": f"{self.root}/lists/index_taxonomy.json",
            "runtime_config.json": f"{self.root}/config/runtime_config.json",
            "symbol_to_token.json": f"{self.root}/mappings/symbol_to_token.json",
            "token_to_symbol.json": f"{self.root}/mappings/token_to_symbol.json",
            "watchlist_tokens.json": f"{self.root}/mappings/watchlist_tokens.json",
            "index_tokens.json": f"{self.root}/mappings/index_tokens.json",
        }

    def read_json(self, name: str):
        path = self.path_map.get(name)
        if not path or not os.path.exists(path):
            return None
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)

class DailyMarketListsProvider:
    def __init__(self, broker, root: str):
        self.broker = broker
        self.root = root.rstrip("/")

    def _read_json(self, path: str, default=None):
        default = [] if default is None else default
        if not os.path.exists(path):
            return default
        try:
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            return data if isinstance(data, list) else default
        except Exception:
            return default

    def _write_json(self, path: str, data):
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "w", encoding="utf-8") as f:
            json.dump(data, f, ensure_ascii=False, indent=2)

    def _is_cash_equity_symbol(self, symbol: str) -> bool:
        s = str(symbol or "").strip().upper()
        if not s:
            return False
        bad_suffixes = ("FUT", "CE", "PE")
        if s.endswith(bad_suffixes):
            return False
        if any(ch.isdigit() for ch in s):
            return False
        return True

    def _filter_cash_equities(self, rows):
        out = []
        for row in rows or []:
            if isinstance(row, str):
                symbol = row.strip().upper()
                if self._is_cash_equity_symbol(symbol):
                    out.append({"symbol": symbol, "source": "filtered"})
            elif isinstance(row, dict):
                symbol = str(row.get("symbol", "")).strip().upper()
                if self._is_cash_equity_symbol(symbol):
                    payload = dict(row)
                    payload["symbol"] = symbol
                    out.append(payload)
        return out            

    @property
    def movers_path(self):
        return f"{self.root}/lists/daily_movers_cache.json"

    @property
    def losers_path(self):
        return f"{self.root}/lists/daily_losers_cache.json"

    @property
    def watchlist_path(self):
        return f"{self.root}/lists/watchlist.json"

    @property
    def potential_path(self):
        return f"{self.root}/lists/potential_stocks.json"
    
    def _normalize_cash_rows(self, rows, source):
        out = []
        seen = set()

        for row in rows or []:
            if isinstance(row, str):
                symbol = row.strip().upper()
                payload = {"symbol": symbol, "source": source, "exchange": "NSE"}
            elif isinstance(row, dict):
                symbol = str(
                    row.get("symbol")
                    or row.get("symbolName")
                    or row.get("metadata", {}).get("symbol")
                    or row.get("meta", {}).get("symbol")
                    or row.get("identifier")
                    or ""
                ).strip().upper()
                if not symbol:
                    continue
                payload = dict(row)
                payload["symbol"] = symbol
                payload.setdefault("source", source)
                payload.setdefault("exchange", "NSE")
            else:
                continue

            if not symbol:
                continue
            if symbol.endswith(("FUT", "CE", "PE")):
                continue
            if any(ch.isdigit() for ch in symbol):
                continue

            if symbol in seen:
                continue
            seen.add(symbol)
            out.append(payload)

        return out

    def _nse_session(self):
        s = requests.Session()
        s.headers.update({
            "User-Agent": (
                "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
                "AppleWebKit/537.36 (KHTML, like Gecko) "
                "Chrome/122.0.0.0 Safari/537.36"
            ),
            "Accept": "application/json, text/plain, */*",
            "Accept-Language": "en-US,en;q=0.9",
            "Referer": "https://www.nseindia.com/market-data/top-gainers-losers",
        })
        # Warm cookies / anti-bot session
        s.get("https://www.nseindia.com/", timeout=15)
        s.get("https://www.nseindia.com/market-data/top-gainers-losers", timeout=15)
        return s

    def _normalize_nse_row(self, row, source):
        if not isinstance(row, dict):
            return None

        symbol = str(
            row.get("symbol")
            or row.get("symbolName")
            or row.get("metadata", {}).get("symbol")
            or row.get("meta", {}).get("symbol")
            or row.get("identifier")
            or ""
        ).strip().upper()

        if not symbol:
            return None

        # keep only cash-equity style symbols
        if symbol.endswith(("FUT", "CE", "PE")) or any(ch.isdigit() for ch in symbol):
            return None

        out = {
            "symbol": symbol,
            "exchange": "NSE",
            "source": source,
        }

        # copy common numeric fields when present
        field_map = {
            "ltp": ["ltp", "lastPrice", "price"],
            "open": ["open"],
            "high": ["high", "dayHigh"],
            "low": ["low", "dayLow"],
            "close": ["previousClose", "close"],
            "netChange": ["netChange", "change"],
            "percentChange": ["pChange", "percentChange", "perChange"],
            "tradeVolume": ["totalTradedVolume", "volume"],
        }
        for dst, keys in field_map.items():
            for k in keys:
                if k in row and row.get(k) is not None:
                    out[dst] = row.get(k)
                    break

        return out

    def _extract_rows_from_nse_json(self, payload):
        # handle several possible shapes
        if isinstance(payload, list):
            return payload

        if not isinstance(payload, dict):
            return []

        for key in (
            "data",
            "value",
            "body",
            "rows",
            "topGainers",
            "topLosers",
            "gainers",
            "losers",
        ):
            val = payload.get(key)
            if isinstance(val, list):
                return val

        # sometimes nested under data
        data = payload.get("data")
        if isinstance(data, dict):
            for key in ("rows", "gainers", "losers", "topGainers", "topLosers"):
                val = data.get(key)
                if isinstance(val, list):
                    return val

        return []

    def _fetch_nse_json_candidates(self, kind: str):
        """
        kind: 'gainers' or 'losers'
        Tries a few likely NSE capital-market JSON paths.
        """
        s = self._nse_session()

        candidate_urls = [
            f"https://www.nseindia.com/api/live-analysis-variations?index={kind}",
            f"https://www.nseindia.com/api/live-analysis-variations?segment=equities&index={kind}",
            f"https://www.nseindia.com/api/market-data-pre-open?key={kind}",
            f"https://www.nseindia.com/api/marketSnapshot?type={kind}",
        ]

        for url in candidate_urls:
            try:
                r = s.get(url, timeout=15)
                if r.status_code != 200:
                    continue
                payload = r.json()
                rows = self._extract_rows_from_nse_json(payload)
                if rows:
                    return rows
            except Exception:
                continue

        return []

    def _fetch_nse_cash_gainers(self):
        rows = self._fetch_nse_json_candidates("gainers")
        out = []
        seen = set()
        for row in rows:
            item = self._normalize_nse_row(row, "nse_gainers")
            if not item:
                continue
            sym = item["symbol"]
            if sym in seen:
                continue
            seen.add(sym)
            out.append(item)
        return out

    def _fetch_nse_cash_losers(self):
        rows = self._fetch_nse_json_candidates("losers")
        out = []
        seen = set()
        for row in rows:
            item = self._normalize_nse_row(row, "nse_losers")
            if not item:
                continue
            sym = item["symbol"]
            if sym in seen:
                continue
            seen.add(sym)
            out.append(item)
        return out

    def get_daily_movers(self):
        rows = self._fetch_nse_cash_gainers()
        self._write_json(self.movers_path, rows)
        return rows

    def get_daily_losers(self):
        rows = self._fetch_nse_cash_losers()
        self._write_json(self.losers_path, rows)
        return rows

    def get_daily_movers(self):
        rows = self._normalize_cash_rows(self._fetch_nse_cash_gainers(), "nse_gainers")
        self._write_json(self.movers_path, rows)
        return rows

    def get_daily_losers(self):
        rows = self._normalize_cash_rows(self._fetch_nse_cash_losers(), "nse_losers")
        self._write_json(self.losers_path, rows)
        return rows

    def build_potential_stocks(self):
        watchlist = self._read_json(self.watchlist_path, default=[])
        movers = self.get_daily_movers()
        losers = self.get_daily_losers()

        seen = set()
        out = []

        def add_rows(rows, source):
            for row in rows or []:
                if isinstance(row, str):
                    symbol = row.strip().upper()
                    payload = {"symbol": symbol, "source": source}
                elif isinstance(row, dict):
                    symbol = str(row.get("symbol", "")).strip().upper()
                    if not symbol:
                        continue
                    payload = dict(row)
                    payload["symbol"] = symbol
                    payload.setdefault("source", source)
                else:
                    continue

                if not symbol or symbol in seen:
                    continue
                seen.add(symbol)
                out.append(payload)

        # Do NOT clone whole watchlist into potential list
        # Potential list should be dynamic
        add_rows(movers, "movers")
        add_rows(losers, "losers")

        # Light fallback only if both are empty
        if not out:
            for row in watchlist[:25]:
                if isinstance(row, str):
                    symbol = row.strip().upper()
                    payload = {"symbol": symbol, "source": "watchlist_fallback"}
                elif isinstance(row, dict):
                    symbol = str(row.get("symbol", "")).strip().upper()
                    if not symbol:
                        continue
                    payload = dict(row)
                    payload["symbol"] = symbol
                    payload.setdefault("source", "watchlist_fallback")
                else:
                    continue

                if symbol and symbol not in seen:
                    seen.add(symbol)
                    out.append(payload)

        self._write_json(self.potential_path, out)
        return out

