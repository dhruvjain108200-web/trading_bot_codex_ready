def load_watchlist_subscription_tokens(path):
    with open(path, "r", encoding="utf-8") as f:
        rows = json.load(f)

    if not isinstance(rows, list):
        raise ValueError("watchlist_tokens.json must be a list of watchlist token rows")

    tokens = []
    unresolved = []
    seen = set()

    for idx, row in enumerate(rows):
        if not isinstance(row, dict):
            raise ValueError(f"watchlist_tokens.json row {idx} must be an object")

        symbol = str(row.get("symbol", "")).strip()
        exchange = str(row.get("exchange", "")).strip()
        sector = str(row.get("sector", "")).strip()
        status = str(row.get("resolution_status", "")).strip().upper()
        token_raw = row.get("token")
        token = str(token_raw).strip() if token_raw is not None else ""

        if not symbol or not exchange or not sector:
            raise ValueError(
                f"watchlist_tokens.json row {idx} is missing symbol/exchange/sector"
            )

        if token:
            if status and status != "RESOLVED":
                raise ValueError(
                    f"watchlist_tokens.json row {idx} has token but invalid resolution_status={status!r}"
                )
            if token not in seen:
                seen.add(token)
                tokens.append(token)
        else:
            if status and status != "UNRESOLVED":
                raise ValueError(
                    f"watchlist_tokens.json row {idx} is unresolved but resolution_status={status!r}"
                )
            unresolved.append(f"{exchange}:{symbol}")

    return {
        "rows": rows,
        "tokens": tokens,
        "unresolved": unresolved,
    }

